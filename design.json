  "copyGuidelines": {
    "tone": "Practical, concise, friendly assistant for travel preparation.",
    "languageStyle": "Short labels and direct verbs.",
    "buttonTextStyle": "Action-first, 1-2 words when possible (Save, Add, Start).",
    "placeholderStyle": "Examples prefixed by e.g. for clarity."
  },
  "iconography": {
    "system": "SF Symbols first",
    "style": "Outlined or medium weight symbols on dark surfaces",
    "defaultSize": 20,
    "emojiUsage": "Allowed inside chips/categories for quick semantic recognition"
  },
  "accessibilityGuidelines": {
    "dynamicType": "Support scaling without clipping in cards and fields.",
    "contrast": "Maintain at least AA contrast; keep body text on dark surfaces in secondary/primary tokens.",
    "touchTargets": "Minimum 44x44 points for interactive controls.",
    "motion": "Use subtle transitions only; avoid large decorative motion."
  },
  "aiImplementationRules": {
    "goal": "Reproduce a cohesive dark, warm-accent travel-planner style consistently across new and existing screens.",
    "mustDo": [
      "Use provided tokens before introducing any new color, spacing or radius values.",
      "Default to card-based composition with rounded dark surfaces and orange primary action.",
      "Keep horizontal screen padding at 16 unless constrained by a full-bleed media section.",
      "Use label + field vertical pairing with 8pt gap for forms.",
      "Prefer one strong primary CTA per screen.",
      "For Trips root screen, keep bottom tab bar persistent and visually separated from content.",
      "For checklist item rows, use split background pattern and preserve swipe-to-delete affordance.",
      "Use only SwiftUI system fonts via Font.system/TextStyle; do not use custom font assets."
    ],
    "mustNotDo": [
      "Do not use bright white backgrounds.",
      "Do not mix unrelated accent colors for primary actions.",
      "Do not create dense multi-column layouts on iPhone portrait.",
      "Do not use heavy borders as a primary separation method.",
      "Do not introduce third-party or bundled custom fonts."
    ],
    "fallbackPolicy": {
      "ifMissingExactSpec": "Reuse nearest matching component from componentLibrary and preserve token usage.",
      "ifNewComponentNeeded": "Compose from existing primitives: card + label + value + action, then apply spacing scale."
    }
  }
}
