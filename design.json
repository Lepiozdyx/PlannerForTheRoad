{
  "meta": {
    "name": "Planner for the Road Design System",
    "version": "1.2.0",
    "platform": "iOS 17+",
    "productContext": {
      "category": "Lifestyle",
      "description": "All-in-one road-trip planner with route planning, places discovery, and smart packing checklist."
    }
  },
  "designPrinciples": [
    "Dark-first visual style with warm orange gradient accents and high-contrast content cards.",
    "Card-centric composition: each meaningful unit (trip, checklist block, stat, place) is a distinct rounded container.",
    "Compact but readable information density using clear vertical rhythm and predictable spacing scale.",
    "Action clarity: one dominant primary CTA per screen, secondary actions rendered as chips or icon buttons.",
    "Mobile ergonomics first: top bar for context, content scroll in middle, key action anchored near bottom.",
    "Use visual hierarchy through color and weight, not heavy borders."
  ],
  "tokens": {
    "colors": {
      "surface": {
        "base": "#0F1014",
        "elevated": "#1B1D25",
        "elevatedAlt": "#1A1C23"
      },
      "text": {
        "primary": "#FFFFFF",
        "secondary": "#C9CED8",
        "tertiary": "#8E94A3"
      },
      "accent": {
        "primary": "#FF8000",
        "secondary": "#F4C542",
        "gradientStart": "#BE662A",
        "gradientEnd": "#4B1600"
      },
      "semantic": {
        "info": "#C9CED8",
        "success": "#34C759",
        "warning": "#FF9F0A",
        "danger": "#FF453A",
        "delete": "#FF8A00"
      },
      "overlay": {
        "shadow": "rgba(0,0,0,0.25)",
        "glowWarm": "rgba(255,46,46,0.15)",
        "cardShadow": "rgba(0,0,0,0.35)"
      }
    },
    "gradients": {
      "screenBackground": {
        "type": "linear",
        "direction": "vertical",
        "stops": [
          {
            "color": "#BE662A",
            "position": 0
          },
          {
            "color": "#4B1600",
            "position": 1
          }
        ],
        "overlayBase": "#0F1014"
      }
    },
    "typography": {
      "fontFamily": "SF Pro (iOS System Font)",
      "swiftUIFontDesign": "default",
      "useDynamicType": true,
      "scale": {
        "title": {
          "size": 20,
          "weight": 600,
          "lineHeight": 28,
          "tracking": -0.45,
          "swiftUITextStyle": "title3",
          "swiftUIFont": ".system(size: 20, weight: .semibold, design: .default)"
        },
        "button": {
          "size": 16,
          "weight": 600,
          "lineHeight": 24,
          "tracking": -0.31,
          "swiftUITextStyle": "headline",
          "swiftUIFont": ".system(size: 16, weight: .semibold, design: .default)"
        },
        "body": {
          "size": 16,
          "weight": 400,
          "lineHeight": 22,
          "tracking": -0.31,
          "swiftUITextStyle": "body",
          "swiftUIFont": ".system(size: 16, weight: .regular, design: .default)"
        },
        "label": {
          "size": 14,
          "weight": 500,
          "lineHeight": 20,
          "tracking": -0.15,
          "swiftUITextStyle": "subheadline",
          "swiftUIFont": ".system(size: 14, weight: .medium, design: .default)"
        },
        "caption": {
          "size": 13,
          "weight": 400,
          "lineHeight": 18,
          "tracking": -0.08,
          "swiftUITextStyle": "caption",
          "swiftUIFont": ".system(size: 13, weight: .regular, design: .default)"
        }
      }
    },
    "spacing": {
      "scale": [4, 8, 12, 16, 20, 24, 32],
      "screenHorizontalPadding": 16,
      "sectionGap": 22,
      "fieldGroupGap": 16,
      "labelToFieldGap": 8,
      "contentTopInset": 72
    },
    "radius": {
      "input": 12,
      "card": 16,
      "button": 16,
      "chip": 999
    },
    "size": {
      "topBarHeight": 56,
      "topBarCompactHeight": 52,
      "inputHeight": 48,
      "photoDropzoneHeight": 148,
      "textAreaHeight": 112,
      "chipHeight": 40,
      "primaryButtonHeight": 56,
      "tabBarHeight": 88,
      "progressBarHeight": 9,
      "segmentedTabHeight": 36,
      "stopCardHeight": 130,
      "checklistRowHeight": 56,
      "iconSmall": 20,
      "touchTargetMin": 44
    },
    "effects": {
      "screenShadow": {
        "x": 0,
        "y": 25,
        "blur": 50,
        "color": "rgba(0,0,0,0.25)"
      },
      "primaryButtonGlow": {
        "x": 0,
        "y": 0,
        "blur": 20,
        "color": "rgba(255,46,46,0.15)"
      }
    }
  },
  "layoutSystem": {
    "grid": {
      "columns": 1,
      "horizontalPadding": 16,
      "maxContentWidthBehavior": "fill"
    },
    "safeAreas": {
      "topHandledBy": "custom top bar + status inset",
      "bottomHandledBy": "sticky CTA or tab bar spacing"
    },
    "scrolling": {
      "default": "vertical",
      "contentInsetBottom": 24
    },
    "hierarchy": {
      "order": [
        "Top navigation context",
        "Primary content blocks",
        "Supportive hints/status",
        "Primary call to action"
      ]
    }
  },
  "componentLibrary": {
    "AppShell": {
      "description": "Dark gradient container wrapping each screen.",
      "style": {
        "background": "gradient.screenBackground",
        "foregroundColorDefault": "text.secondary"
      }
    },
    "TopNavigationBar": {
      "description": "Compact bar with back icon and title.",
      "structure": ["leading icon button", "screen title"],
      "style": {
        "height": "size.topBarHeight",
        "titleTypography": "typography.scale.title",
        "iconSize": "size.iconSmall",
        "paddingHorizontal": 16
      }
    },
    "TopTitleBar": {
      "description": "Top bar with title only (used on Trips screen).",
      "structure": ["screen title"],
      "style": {
        "height": "size.topBarCompactHeight",
        "titleTypography": "typography.scale.title",
        "titleWeight": 700,
        "paddingHorizontal": 16
      }
    },
    "TextField": {
      "description": "Single-line input field for short values.",
      "style": {
        "height": "size.inputHeight",
        "background": "colors.surface.elevated",
        "radius": "radius.input",
        "text": "typography.scale.body",
        "placeholderColor": "colors.text.tertiary",
        "contentPaddingHorizontal": 16,
        "contentPaddingVertical": 12
      },
      "label": {
        "typography": "typography.scale.label",
        "color": "colors.text.secondary",
        "gapToField": "spacing.labelToFieldGap"
      },
      "states": {
        "default": {
          "background": "#1B1D25"
        },
        "focused": {
          "outlineColor": "#FF8000",
          "outlineWidth": 1
        },
        "disabled": {
          "opacity": 0.5
        }
      }
    },
    "TextArea": {
      "description": "Multi-line field for route or notes.",
      "style": {
        "height": "size.textAreaHeight",
        "background": "colors.surface.elevated",
        "radius": "radius.input",
        "padding": 12,
        "text": "typography.scale.body"
      }
    },
    "Chip": {
      "description": "Pill selector for checklist type and filters.",
      "style": {
        "height": "size.chipHeight",
        "radius": "radius.chip",
        "paddingHorizontal": 16,
        "typography": "typography.scale.label"
      },
      "states": {
        "selected": {
          "background": "#FF8000",
          "textColor": "#FFFFFF"
        },
        "unselected": {
          "background": "#1B1D25",
          "textColor": "#C9CED8"
        }
      }
    },
    "PrimaryButton": {
      "description": "Main conversion button for screen actions.",
      "style": {
        "height": "size.primaryButtonHeight",
        "radius": "radius.button",
        "background": "colors.accent.primary",
        "text": "typography.scale.button",
        "textColor": "#FFFFFF",
        "shadow": "effects.primaryButtonGlow"
      }
    },
    "BottomTabBar": {
      "description": "Three-tab bottom navigation with icon above label and active orange state.",
      "style": {
        "height": "size.tabBarHeight",
        "background": "#1A1D2A",
        "activeColor": "#FF8000",
        "inactiveColor": "#C9CED8",
        "iconSize": 22,
        "labelTypography": "typography.scale.caption"
      },
      "layout": {
        "itemsCount": 3,
        "distribution": "equalWidth",
        "topPadding": 10,
        "bottomPadding": 8
      }
    },
    "ProgressBar": {
      "description": "Slim rounded progress line used in trip card packing progress.",
      "style": {
        "height": "size.progressBarHeight",
        "trackColor": "#2A2F42",
        "fillColor": "#F4C542",
        "radius": 999
      },
      "label": {
        "leftText": "Packing Progress",
        "rightValueFormat": "percent"
      }
    },
    "SegmentedTopTabs": {
      "description": "Three-part top tab row with thin active underline.",
      "style": {
        "height": "size.segmentedTabHeight",
        "activeTextColor": "#FFFFFF",
        "inactiveTextColor": "#C9CED8",
        "activeIndicatorColor": "#FF8A00",
        "activeIndicatorHeight": 2,
        "dividerColor": "rgba(255,138,0,0.45)"
      },
      "layout": {
        "items": ["Route", "Places", "Checklist"],
        "distribution": "equalWidth"
      }
    },
    "DualMetricCard": {
      "description": "Wide card with two key metrics side by side.",
      "style": {
        "background": "#1B1D25",
        "radius": 16,
        "padding": 16
      },
      "contentSlots": [
        "metricLeftLabel",
        "metricLeftValue",
        "metricRightLabel",
        "metricRightValue"
      ]
    },
    "RouteStopCard": {
      "description": "Stop card inside route tab with title, distance, place chip, and add action.",
      "style": {
        "height": "size.stopCardHeight",
        "background": "#1B1D25",
        "radius": 16,
        "padding": 16,
        "titleTypography": "typography.scale.button",
        "subtitleTypography": "typography.scale.body"
      },
      "contentSlots": [
        "stopTitle",
        "distanceFromStart",
        "placePill",
        "addPlaceAction"
      ]
    },
    "ChecklistTypeCard": {
      "description": "Card representing one checklist type with packed count and chevron.",
      "style": {
        "background": "#1B1D25",
        "radius": 16,
        "padding": 16,
        "minHeight": 112
      },
      "contentSlots": [
        "emojiAndTitle",
        "packedRatioText",
        "progressBar",
        "chevron"
      ]
    },
    "ChecklistSwipeRow": {
      "description": "Checklist row with selectable left area and orange delete trailing action.",
      "style": {
        "height": "size.checklistRowHeight",
        "containerRadius": 12,
        "leftBackground": "#1B1D25",
        "rightBackground": "#FF8A00",
        "rightWidthRatio": 0.27,
        "checkedIconColor": "#F4C542",
        "uncheckedStrokeColor": "#2A2F42"
      },
      "states": {
        "checked": {
          "textColor": "#8E94A3",
          "textDecoration": "lineThrough"
        },
        "unchecked": {
          "textColor": "#FFFFFF",
          "textDecoration": "none"
        }
      }
    },
    "BarChartCard": {
      "description": "Dark card with monthly bar chart for distance analytics.",
      "style": {
        "background": "#1B1D25",
        "radius": 16,
        "padding": 16,
        "gridColor": "rgba(201,206,216,0.14)",
        "axisColor": "#C9CED8",
        "barPrimaryColor": "#FF8A00",
        "barHighlightColor": "#F4C542"
      }
    },
    "RankingTripRow": {
      "description": "Top trips row with circular rank badge, route title, and distance.",
      "style": {
        "background": "#1B1D25",
        "radius": 14,
        "padding": 14,
        "rankBadgeSize": 34,
        "distanceColor": "#F4C542"
      }
    },
    "PhotoDropzone": {
      "description": "Large dark rounded rectangle used for optional item photo upload.",
      "style": {
        "height": "size.photoDropzoneHeight",
        "background": "#1B1D25",
        "radius": 16,
        "borderWidth": 1,
        "borderColor": "rgba(255,128,0,0.2)",
        "placeholderColor": "#8E94A3",
        "placeholderTypography": "typography.scale.body"
      }
    },
    "InfoBanner": {
      "description": "Supportive helper message card with leading icon.",
      "style": {
        "background": "#1B1D25",
        "radius": "radius.card",
        "padding": 16,
        "iconSize": 20,
        "textTypography": "typography.scale.label",
        "textColor": "#C9CED8"
      }
    },
    "TripCard": {
      "description": "Primary summary card for route overview.",
      "style": {
        "background": "#1B1D25",
        "radius": 16,
        "padding": 16,
        "shadowColor": "rgba(0,0,0,0.35)",
        "shadowBlur": 12,
        "titleTypography": "typography.scale.button",
        "metaTypography": "typography.scale.label",
        "supportTypography": "typography.scale.caption"
      },
      "contentSlots": [
        "tripTitle",
        "chevronAction",
        "distanceKm",
        "travelTime",
        "packingProgressLabel",
        "packingProgressPercent",
        "packingProgressBar"
      ]
    },
    "PlaceCard": {
      "description": "Card for scenic place with media and rating.",
      "style": {
        "background": "#1B1D25",
        "radius": 16,
        "imageCornerRadius": 12,
        "contentPadding": 12
      },
      "contentSlots": [
        "thumbnail",
        "placeName",
        "shortDescription",
        "rating",
        "distanceOrEta"
      ]
    },
    "ChecklistItem": {
      "description": "Single checklist row with completion control.",
      "style": {
        "background": "#1B1D25",
        "radius": 12,
        "paddingHorizontal": 12,
        "paddingVertical": 10,
        "textTypography": "typography.scale.label"
      },
      "states": {
        "unchecked": {
          "textColor": "#C9CED8"
        },
        "checked": {
          "textColor": "#8E94A3",
          "textDecoration": "lineThrough",
          "accentColor": "#34C759"
        }
      }
    },
    "StatisticsCard": {
      "description": "Compact metric card for totals and top rankings.",
      "style": {
        "background": "#1B1D25",
        "radius": 16,
        "padding": 16
      },
      "contentSlots": [
        "metricLabel",
        "metricValue",
        "deltaOrHint"
      ]
    }
  },
